{#
 # System Logs Index - Using cp-table layout
 #
 # This template extends the base plugin's cp-table layout to provide
 # a consistent interface for viewing system logs with filters, sorting,
 # expandable row details, and a sidebar with log configuration info.
 #
 # Supports two modes:
 # - Plugin mode: Shows logs for a specific plugin (date-based files)
 # - Standalone mode: Shows all system logs (source/file-based)
 #}

{% extends 'lindemannrock-base/_layouts/cp-table' %}

{# ============================================================================
   BUILD FILTER OPTIONS
   ============================================================================ #}

{# Build level options #}
{% set levelOptions = [
    {value: 'all', label: 'All Levels'|t('logging-library'), status: 'all'},
] %}

{% set levelSeverity = {
    'error': 1,
    'warning': 2,
    'info': 3,
    'debug': 4
} %}
{% set configuredLevel = logConfig ? logConfig.logLevel|lower : 'debug' %}
{% set configuredSeverity = levelSeverity[configuredLevel] ?? 4 %}

{% for value, label in levels %}
    {% if value != 'all' %}
        {% if isStandalone or (levelSeverity[value] is defined and levelSeverity[value] <= configuredSeverity) %}
            {% if value != 'debug' or craft.app.config.general.devMode %}
                {% set levelOptions = levelOptions|merge([{
                    value: value,
                    label: label,
                    colorKey: value,
                }]) %}
            {% endif %}
        {% endif %}
    {% endif %}
{% endfor %}

{# Build file/date options.
   `label` is the full filename + size, shown in the dropdown options.
   `shortLabel` is just the date, shown in the button once a file is selected
   (the source filter already tells the user which plugin/source they're on). #}
{% set fileOptions = [{value: '', label: isStandalone ? 'Select File'|t('logging-library') : 'Select Date'|t('logging-library')}] %}
{% for file in logFiles %}
    {% set fileOptions = fileOptions|merge([{
        value: isStandalone ? file.filename : file.date,
        label: (isStandalone ? file.filename : file.date) ~ ' (' ~ file.formattedSize ~ ')',
        shortLabel: file.date,
        extraParams: {category: 'all'},
    }]) %}
{% endfor %}

{% set supportsCategoryFilter = selectedFile and ((selectedFile.source ?? '') in ['web', 'queue', 'console']) %}
{% set categoryFilter = supportsCategoryFilter and categoryOptions|length > 1 ? {
    type: 'dropdown',
    param: 'category',
    current: filters.category,
    label: filters.category == 'all' ? 'Source'|t('logging-library') : filters.category,
    options: categoryOptions,
    menuStyle: 'min-width: 320px;',
} : null %}
{# In standalone mode, files have a `filename` key; in plugin mode they have `date`. Guard both accesses against the other mode + null `selectedFile`. #}
{% set selectedStandaloneFile = (isStandalone and selectedFile and selectedFile.filename is defined) ? selectedFile.filename : '' %}
{% set selectedPluginDate = (not isStandalone and selectedFile and selectedFile.date is defined) ? selectedFile.date : '' %}

{% set standaloneFilters = [
    {
        type: 'status',
        param: 'source',
        current: filters.source,
        label: sources[filters.source] ?? 'All Sources'|t('logging-library'),
        colorSet: 'logSource',
        groups: sourceGroups,
    },
    {
        type: 'dropdown',
        param: 'file',
        current: selectedStandaloneFile,
        label: selectedStandaloneFile ?: 'Select File'|t('logging-library'),
        options: fileOptions,
    },
    {
        type: 'status',
        param: 'level',
        current: filters.level,
        label: levels[filters.level] ?? 'All Levels'|t('logging-library'),
        colorSet: 'logLevel',
        options: levelOptions,
    },
] %}

{% set pluginFilters = [
    {
        type: 'dropdown',
        param: 'date',
        current: selectedPluginDate,
        label: selectedPluginDate ?: 'Select Date'|t('logging-library'),
        options: fileOptions,
    },
    {
        type: 'status',
        param: 'level',
        current: filters.level,
        label: levels[filters.level] ?? 'All Levels'|t('logging-library'),
        colorSet: 'logLevel',
        options: levelOptions,
    },
] %}

{% if categoryFilter %}
    {% set standaloneFilters = standaloneFilters|merge([categoryFilter]) %}
    {% set pluginFilters = pluginFilters|merge([categoryFilter]) %}
{% endif %}

{# ============================================================================
   TABLE CONFIGURATION
   ============================================================================ #}

{% set sidebarItems = logMenuItems ?? (isStandalone ? {} : {
    system: {label: 'System'|t('logging-library'), url: pluginHandle ~ '/logs/system'},
}) %}
{% set sidebarLabel = logMenuLabel ?? 'Logs'|t('logging-library') %}

{% set tableConfig = {
    plugin: {
        handle: pluginHandle,
        name: pluginName,
    },
    page: {
        title: 'System Logs'|t('logging-library'),
        subnav: isStandalone ? 'all-logs' : 'logs',
        crumbs: isStandalone ? [
            { label: pluginName, url: url('logging-library') },
            { label: 'All Logs'|t('logging-library'), url: url('logging-library') },
        ] : [
            { label: pluginName, url: url(pluginHandle) },
            { label: 'Logs'|t('logging-library'), url: url(pluginHandle ~ '/logs/') },
            { label: 'System'|t('logging-library'), url: url(pluginHandle ~ '/logs/system') }
        ],
    },
    sidebarMenu: {
        label: sidebarLabel,
        items: sidebarItems,
        selected: 'system',
    },
    filters: isStandalone ? standaloneFilters : pluginFilters,
    search: {
        placeholder: 'Search messages and context...'|t('logging-library'),
        value: filters.search,
    },
    sort: {
        field: filters.sort,
        direction: filters.dir,
    },
    table: {
        columns: (isStandalone and supportsCategoryFilter) ? [
            {key: 'timestamp', label: 'Time'|t('logging-library'), sortable: true, width: '140px'},
            {key: 'level', label: 'Level'|t('logging-library'), sortable: true, width: '80px'},
            {key: 'category', label: 'Source'|t('logging-library'), sortable: true},
            {key: 'user', label: 'User'|t('logging-library'), sortable: true, width: '100px'},
            {key: 'message', label: 'Message'|t('logging-library'), sortable: true},
        ] : [
            {key: 'timestamp', label: 'Time'|t('logging-library'), sortable: true, width: '140px'},
            {key: 'level', label: 'Level'|t('logging-library'), sortable: true, width: '80px'},
            {key: 'user', label: 'User'|t('logging-library'), sortable: true, width: '100px'},
            {key: 'message', label: 'Message'|t('logging-library'), sortable: true},
        ],
        items: logEntries,
        emptyMessage: logFiles|length == 0
            ? 'No log files found. Log files are created when plugin activities occur.'|t('logging-library')
            : 'No log entries found for the selected filters.'|t('logging-library'),
        expandable: true,
        rowClassKey: 'levelClass',
    },
    pagination: {
        page: pagination.currentPage,
        limit: pagination.perPage,
        totalCount: pagination.total,
        itemLabel: {singular: 'entry'|t('logging-library'), plural: 'entries'|t('logging-library')},
    },
    checkboxes: false,
    rowActions: false,
} %}


{# ============================================================================
   BEFORE TABLE - Empty state info
   ============================================================================ #}

{% block beforeTable %}
    {% include 'lindemannrock-base/_partials/styles-log-level-rows' only %}

    <style>
        table#lr-data-table {
            table-layout: fixed;
        }
        .lr-log-pre {
            margin: 0;
            font-family: Monaco, 'Courier New', monospace;
            font-size: 12px;
            white-space: pre-wrap;
            overflow-x: auto;
        }
    </style>

    {% if logFiles|length == 0 and logConfig %}
        <div class="info-box-table-wrapper">
            {% include 'lindemannrock-base/_components/info-box' with {
                message: 'Current log level'|t('logging-library') ~ ': <strong>' ~ logConfig.logLevel|capitalize|t('logging-library')|upper ~ '</strong>',
                type: 'tip',
                margin: 'none',
                stretch: true,
            } %}
        </div>
    {% endif %}
{% endblock %}


{# ============================================================================
   CUSTOM TABLE ROW RENDERING
   ============================================================================ #}

{% block tableRow %}
    {# Timestamp #}
    <td class="nowrap code">
        <time datetime="{{ item.timestamp|lrToApiString }}">{{ item.timestamp|lrTime('short', null, false) }}</time>
    </td>

    {# Level — `canonicalLevel` and `levelClass` are precomputed in the
       controller (LogsController::_getLogPageFromFile). `levelClass` is
       applied to the parent <tr> via `tableConfig.rowClassKey` and drives
       row-tint CSS in `lindemannrock-base/_partials/styles-log-level-rows`. #}
    {% set levelValue = item.level ?: 'unknown' %}
    {% set canonicalLevel = item.canonicalLevel ?? '' %}
    {% set isCanonical = canonicalLevel != '' %}
    <td>
        {% if isCanonical %}
            {% include 'lindemannrock-base/_components/badge' with {
                label: (levels[canonicalLevel] ?? canonicalLevel|title)|upper,
                value: canonicalLevel,
                colorSet: 'logLevel',
            } only %}
        {% else %}
            <span class="light code">{{ (levels[levelValue] ?? levelValue|replace({'-': ' ', '_': ' '})|title)|upper }}</span>
        {% endif %}
    </td>

    {# Category/Source — shown only for multi-category sources (web/queue/console).
       For php-errors and plugin-specific logs the value is uniform across rows. #}
    {% if isStandalone and supportsCategoryFilter %}
        {% set sourceLabel = item.category ?: (selectedFile.source ?? 'unknown') %}
        <td class="truncate" title="{{ sourceLabel }}">{{ sourceLabel }}</td>
    {% endif %}

    {# User #}
    <td class="nowrap">
        {% if item.user matches '/user:(\\d+)/' %}
            {% set userId = item.user|replace('user:', '') %}
            {% set user = craft.users.id(userId).one() %}
            {{ user ? user.username : 'User #{id}'|t('logging-library', {id: userId}) }}
        {% else %}
            {{ item.user ?: 'System'|t('logging-library') }}
        {% endif %}
    </td>

    {# Message + context inline; click row to see them on separate lines. #}
    {% set previewText = item.message ~ ((item.context and item.context not in ['[]', '']) ? ' ' ~ item.context : '') %}
    <td class="truncate" title="{{ previewText }}">
        {{ previewText|e }}
    </td>
{% endblock %}


{# ============================================================================
   EXPANDABLE ROW DETAILS
   ============================================================================ #}

{% block expandableRow %}
    <pre class="lr-log-pre">{{ item.message|e }}</pre>

    {% if item.context and item.context != '[]' and item.context != '' %}
        <pre class="lr-log-pre" style="margin-top: 12px;">{{ item.context|e }}</pre>
    {% endif %}
{% endblock %}


{# ============================================================================
   SIDEBAR - Log Configuration Info
   ============================================================================ #}

{% block sidebarContent %}
    <style>
        .log-config-item {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 8px;
            align-items: center;
            padding: 6px 0;
        }
        .log-config-item:not(:last-child) {
            border-bottom: 1px solid rgba(51, 64, 77, 0.1);
        }
        .log-config-item .label {
            color: #596673;
            font-weight: normal;
            white-space: nowrap;
        }
        .log-config-item .value {
            text-align: right;
            word-break: break-word;
        }
        .log-config-item.location {
            grid-template-columns: 1fr;
            align-items: start;
        }
        .log-config-item.location .value {
            text-align: left;
            margin-top: 4px;
        }
    </style>

    <div class="meta" style="padding: 12px;">
        {% if not isStandalone and logConfig %}
            <div class="log-config-item">
                <div class="label">{{ "Current Level"|t('logging-library') }}</div>
                <div class="value">
                    {% include 'lindemannrock-base/_components/badge' with {
                        label: logConfig.logLevel|capitalize|t('logging-library')|upper,
                        value: logConfig.logLevel|lower,
                        colorSet: 'logLevel',
                    } only %}
                </div>
            </div>

            <div class="log-config-item">
                <div class="label">{{ "Retention"|t('logging-library') }}</div>
                <div class="value">{{ logConfig.retention }} {{ "days"|t('logging-library') }}</div>
            </div>
        {% endif %}

        <div class="log-config-item">
            <div class="label">{{ "Available Logs"|t('logging-library') }}</div>
            <div class="value">{{ logFiles|length|number_format }} {{ logFiles|length == 1 ? 'file'|t('logging-library') : 'files'|t('logging-library') }}</div>
        </div>

        {% if selectedFile %}
            {% set selectedFileParams = isStandalone
                ? {file: selectedStandaloneFile, pluginHandle: pluginHandle}
                : {date: selectedPluginDate, pluginHandle: pluginHandle}
            %}

            <div class="log-config-item">
                <div class="label">{{ "Current File"|t('logging-library') }}</div>
                <div class="value">{{ selectedFile.formattedSize }}</div>
            </div>

            <div class="log-config-item">
                <div class="label">{{ "Entries"|t('logging-library') }}</div>
                <div class="value">{{ pagination.total|number_format }}</div>
            </div>

            <div class="log-config-item" style="grid-template-columns: 1fr; padding: 8px 0;">
                <form method="post" accept-charset="UTF-8" id="refresh-log-cache-form">
                    {{ csrfInput() }}
                    {{ actionInput('logging-library/logs/refresh-cache') }}
                    {{ redirectInput(craft.app.request.url) }}
                    {{ hiddenInput('pluginHandle', pluginHandle) }}
                    {% if isStandalone %}
                        {{ hiddenInput('file', selectedStandaloneFile) }}
                    {% else %}
                        {{ hiddenInput('date', selectedPluginDate) }}
                    {% endif %}
                    <button type="submit" class="btn fullwidth" id="refresh-log-cache">
                        <div class="inline-flex">
                            <div class="label">{{ "Refresh Cache"|t('logging-library') }}</div>
                        </div>
                        <div class="spinner spinner-absolute">
                            <span class="visually-hidden">{{ "Loading"|t('app') }}</span>
                        </div>
                    </button>
                </form>
                <script>
                document.addEventListener('DOMContentLoaded', function() {
                    const refreshForm = document.getElementById('refresh-log-cache-form');
                    const refreshButton = document.getElementById('refresh-log-cache');
                    if (!refreshForm || !refreshButton || !window.jQuery) {
                        return;
                    }
                    jQuery(refreshForm).on('submit', function(e) {
                        e.preventDefault();
                        const $button = jQuery(refreshButton);
                        $button.addClass('loading').prop('disabled', true);
                        jQuery.ajax({
                            url: '{{ actionUrl('logging-library/logs/refresh-cache')|raw }}',
                            type: 'POST',
                            dataType: 'json',
                            data: jQuery(refreshForm).serialize(),
                            success: function(response) {
                                if (response && response.success) {
                                    Craft.cp.displayNotice(response.message || '{{ "Log cache refreshed."|t('logging-library')|e('js') }}');
                                    setTimeout(function() { window.location.reload(); }, 300);
                                } else {
                                    Craft.cp.displayError('{{ "Failed to refresh log cache."|t('logging-library')|e('js') }}');
                                }
                            },
                            error: function() {
                                Craft.cp.displayError('{{ "Failed to refresh log cache."|t('logging-library')|e('js') }}');
                            },
                            complete: function() {
                                $button.removeClass('loading').prop('disabled', false);
                            }
                        });
                    });
                });
                </script>
            </div>

            {% if canDownload %}
                <div class="log-config-item" style="grid-template-columns: 1fr; padding: 8px 0;">
                    <a href="{{ actionUrl('logging-library/logs/download', selectedFileParams) }}" class="btn submit fullwidth" download>
                        {{ "Download File"|t('logging-library') }}
                    </a>
                </div>
            {% endif %}
        {% endif %}

        <div class="log-config-item location">
            <div class="label">{{ "Log Location"|t('logging-library') }}</div>
            <div class="value">
                <code style="font-size: 10px; line-height: 1.5; color: #606d7b; word-break: break-all; display: block;">
                    {% if isStandalone %}
                        storage/logs/
                    {% else %}
                        storage/logs/{{ pluginHandle }}-{date}.log
                    {% endif %}
                </code>
            </div>
        </div>
    </div>
{% endblock %}


