{# Runtime log row rendered for AJAX refresh responses. #}
<tr class="lr-data-row lr-clickable-row {{ item.levelClass ?? '' }}"
    data-id="{{ item.id ?? rowIndex }}"
    data-entry-id="{{ rowIndex }}"
    data-runtime-refresh-row="true"
    data-selectable="true">
    <td class="nowrap code" data-column="timestamp">
        <time datetime="{{ item.timestamp|lrToApiString }}">
            {{ item.timestamp|lrTime('cascade', null, false) }}
        </time>
    </td>

    {% set levelValue = item.level ?: 'unknown' %}
    {% set canonicalLevel = item.canonicalLevel ?? '' %}
    <td data-column="level">
        {% if canonicalLevel %}
            {% include 'lindemannrock-base/_components/badge' with {
                label: (levels[canonicalLevel] ?? canonicalLevel|title)|upper,
                value: canonicalLevel,
                colorSet: 'logLevel',
            } only %}
        {% else %}
            <span class="light code">{{ (levels[levelValue] ?? levelValue|replace({'-': ' ', '_': ' '})|title)|upper }}</span>
        {% endif %}
    </td>

    {% set sourceLabel = item.category ?: 'unknown' %}
    <td class="truncate" data-column="category" title="{{ sourceLabel }}">{{ sourceLabel }}</td>

    <td class="nowrap" data-column="user">
        {% if item.user matches '/user:(\\d+)/' %}
            {% set userId = item.user|replace('user:', '') %}
            {% set user = craft.users.id(userId).one() %}
            {{ user ? user.username : 'User #{id}'|t('logging-library', {id: userId}) }}
        {% else %}
            {{ item.user ?: 'System'|t('logging-library') }}
        {% endif %}
    </td>

    {% set previewText = item.message ~ ((item.context and item.context not in ['[]', '']) ? ' ' ~ item.context : '') %}
    <td class="truncate" data-column="message" title="{{ previewText }}">
        {{ previewText|e }}
    </td>
</tr>

<tr class="lr-context-row" data-entry-id="{{ rowIndex }}" style="display: none;">
    <td colspan="5">
        <div class="lr-context-content">
            <pre class="lr-log-pre">{{ item.message|e }}</pre>

            {% if item.context and item.context != '[]' and item.context != '' %}
                <pre class="lr-log-pre" style="margin-top: 12px;">{{ item.context|e }}</pre>
            {% endif %}
        </div>
    </td>
</tr>
