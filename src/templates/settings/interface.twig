{% extends "logging-library/_layouts/settings" %}
{% import "_includes/forms" as forms %}

{% set title = "Interface Settings"|t('logging-library') %}
{% set fullPageForm = true %}
{% set selectedSettingsItem = 'interface' %}
{% set cpSectionUrl = settings.standaloneViewerAvailable ? 'logging-library' : 'logging-library/settings' %}

{% set crumbs = [
    {
        label: loggingLibraryHelper.fullName|t('logging-library'),
        url: url(cpSectionUrl),
    },
    {
        label: 'Settings'|t('logging-library'),
        url: url('logging-library/settings'),
    },
    {
        label: 'Interface'|t('logging-library'),
        url: url('logging-library/settings/interface'),
    },
] %}

{% block content %}
    {{ actionInput('logging-library/settings/save') }}
    {{ redirectInput('logging-library/settings/interface') }}
    {{ hiddenInput('section', 'interface') }}

        <h2 class="first">{{ "Interface Settings"|t('logging-library') }}</h2>

        {% include 'lindemannrock-base/_partials/items-per-page-field' with {
            settings: settings,
            pluginHandle: 'logging-library',
            instructions: 'Number of log entries to display per page in the log viewers'|t('logging-library'),
        } only %}

        <hr>

        {% include 'lindemannrock-base/_partials/base-overrides' with {
            settings: settings,
            pluginHandle: 'logging-library',
            sections: {
                dateFormat: { fields: ['timeFormat', 'showSeconds'] },
            },
        } only %}

    {% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}
