{
	"name": "lindemannrock/craft-logging-library",
	"description": "Reusable logging library for Craft CMS plugins",
	"type": "craft-plugin",
	"version": "5.10.1",
	"keywords": [
		"craft",
		"cms",
		"craftcms",
		"craft-plugin",
		"logging",
		"library"
	],
	"license": "MIT",
	"authors": [
		{
			"name": "Bilal Hary Lindemann",
			"email": "bh@lindemannrock.com",
			"homepage": "https://lindemannrock.com",
			"role": "Developer"
		}
	],
	"support": {
		"email": "support@lindemannrock.com",
		"issues": "https://github.com/LindemannRock/craft-logging-library/issues",
		"source": "https://github.com/LindemannRock/craft-logging-library",
		"docs": "https://github.com/LindemannRock/craft-logging-library/blob/main/README.md",
		"rss": "https://github.com/LindemannRock/craft-logging-library/commits/main.atom"
	},
	"require": {
		"php": "^8.2",
		"craftcms/cms": "^5.0.0",
		"yii2mod/yii2-array-query": "^1.4",
		"lindemannrock/craft-plugin-base": "^5.0"
	},
	"require-dev": {
		"craftcms/ecs": "dev-main",
		"craftcms/phpstan": "dev-main",
		"phpunit/phpunit": "^11.0"
	},
	"autoload": {
		"psr-4": {
			"lindemannrock\\logginglibrary\\": "src/",
			"lindemannrock\\logginglibrary\\tests\\": "tests/"
		}
	},
	"scripts": {
		"phpstan": "phpstan --ansi --memory-limit=1G",
		"check-cs": "ecs check --ansi",
		"fix-cs": "ecs check --fix --ansi",
		"test": "phpunit --colors=always",
		"ci": [
			"@phpstan",
			"@check-cs"
		],
		"ci:full": [
			"@ci",
			"@test"
		],
		"install-hooks": "git config core.hooksPath .githooks 2>/dev/null || true",
		"post-install-cmd": "@install-hooks",
		"post-update-cmd": "@install-hooks"
	},
	"config": {
		"allow-plugins": {
			"craftcms/plugin-installer": true,
			"yiisoft/yii2-composer": true,
			"php-http/discovery": true
		}
	},
	"extra": {
		"name": "Logging Library",
		"handle": "logging-library",
		"developer": "LindemannRock",
		"developerUrl": "https://lindemannrock.com",
		"class": "lindemannrock\\logginglibrary\\LoggingLibrary"
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
